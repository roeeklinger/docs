{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "BitKit",
  "colors": {
    "primary": "#7f8fff",
    "light": "#7f8fff",
    "dark": "#7f8fff"
  },
  "navbar": {
    "links": [
      {
        "label": "Book a Demo",
        "href": "https://bitkit-blond.vercel.app/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://bitkit-blond.vercel.app/"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": "css-variables"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/bitkit",
          "icon": "brand-github"
        },
        {
          "anchor": "Status",
          "href": "https://status.example.com",
          "icon": "chart-bar"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/natural-language-queries",
              "concepts/data-sources",
              "concepts/data-stitching",
              "concepts/jobs-and-scheduling"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/brand-monitoring",
              "guides/sentiment-analysis",
              "guides/competitor-intelligence",
              "guides/exporting-data"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/rest-api",
              "integrations/python-sdk",
              "integrations/typescript-sdk",
              "integrations/go-sdk",
              "integrations/webhooks",
              "integrations/s3-storage"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "account/plans-and-billing",
              "account/privacy-and-data",
              "account/api-keys"
            ]
          }
        ]
      },
      {
        "tab": "Guide"
      },
      {
        "tab": "API References"
      },
      {
        "tab": "FAQ"
      }
    ]
  },
  "description": "Learn how to use the BitKit platform",
  "background": {
    "color": {
      "light": "#030712",
      "dark": "#030712"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "tabler"
  },
  "favicon": "/images/favicon.svg",
  "logo": "/images/FlattenedTransparentNoPadding.svg"
}
